# Copy to .env and adjust as needed. All values are optional — sensible
# defaults are baked in (see config/index.js).

# HTTP port the server listens on.
PORT=3000

# Environment: development | production | test
NODE_ENV=development

# Storage backend: sqlite (persistent, default) | memory (volatile)
STORE=sqlite

# Path to the SQLite database file (created automatically).
DATABASE_FILE=./data/pulse-check.db

# Rate limiting for write endpoints (per IP).
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
